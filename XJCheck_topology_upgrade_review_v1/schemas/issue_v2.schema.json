{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xjcheck.local/schemas/issue_v2.schema.json",
  "title": "XJCheck Issue V2",
  "type": "object",
  "required": ["issue_id", "rule_id", "severity", "decision_mode", "confidence", "summary", "evidence_refs", "witness_path"],
  "properties": {
    "issue_id": {"type": "string"},
    "rule_id": {"type": "string"},
    "rule_version": {"type": "string"},
    "severity": {"enum": ["critical", "major", "minor", "review", "info"]},
    "decision_mode": {"enum": ["automatic", "review_required", "suppressed"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "summary": {"type": "string"},
    "explanation": {"type": "string"},
    "sheet_ids": {"type": "array", "items": {"type": "string"}},
    "object_ids": {"type": "array", "items": {"type": "string"}},
    "evidence_refs": {"type": "array", "items": {"type": "string"}},
    "witness_path": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["object_type", "object_id", "reason"],
        "properties": {
          "object_type": {"type": "string"},
          "object_id": {"type": "string"},
          "sheet_id": {"type": ["string", "null"]},
          "coord": {
            "type": ["array", "null"],
            "items": {"type": "number"},
            "minItems": 2,
            "maxItems": 2
          },
          "reason": {"type": "string"}
        }
      }
    },
    "weakest_evidence": {"type": ["string", "null"]},
    "alternatives": {"type": "array", "items": {"type": "object"}},
    "recommended_action": {"type": "string"},
    "status": {"enum": ["open", "resolved", "ignored", "false_positive"]}
  },
  "additionalProperties": true
}
