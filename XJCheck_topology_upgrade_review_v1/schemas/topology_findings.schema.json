{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xjcheck.local/schemas/topology_findings.schema.json",
  "title": "XJCheck Topology Findings V2",
  "type": "object",
  "required": ["schema_version", "run_id", "project_id", "topology_decisions", "networks"],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "run_id": {"type": "string"},
    "project_id": {"type": "string"},
    "reader": {"type": "object", "additionalProperties": true},
    "topology_decisions": {
      "type": "array",
      "items": {"$ref": "#/$defs/decision"}
    },
    "networks": {
      "type": "array",
      "items": {"$ref": "#/$defs/network"}
    },
    "semantic_attachments": {
      "type": "array",
      "items": {"$ref": "#/$defs/attachment"}
    },
    "cross_page_matches": {
      "type": "array",
      "items": {"$ref": "#/$defs/crossPageMatch"}
    }
  },
  "$defs": {
    "point": {
      "type": "array",
      "prefixItems": [{"type": "number"}, {"type": "number"}],
      "minItems": 2,
      "maxItems": 2
    },
    "decision": {
      "type": "object",
      "required": ["decision_id", "sheet_id", "relation_type", "object_a", "object_b", "state", "final_confidence", "reason_codes"],
      "properties": {
        "decision_id": {"type": "string"},
        "sheet_id": {"type": "string"},
        "relation_type": {"type": "string"},
        "object_a": {"type": "string"},
        "object_b": {"type": "string"},
        "state": {"enum": ["ASSERTED", "POSSIBLE", "REJECTED", "UNKNOWN"]},
        "rule_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "symbol_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "model_score": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "final_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "evidence_ids": {"type": "array", "items": {"type": "string"}},
        "alternatives": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "network": {
      "type": "object",
      "required": ["network_id", "sheet_id", "member_edge_ids", "open_endpoint_ids", "confidence"],
      "properties": {
        "network_id": {"type": "string"},
        "sheet_id": {"type": "string"},
        "member_edge_ids": {"type": "array", "items": {"type": "string"}},
        "junction_ids": {"type": "array", "items": {"type": "string"}},
        "symbol_port_ids": {"type": "array", "items": {"type": "string"}},
        "open_endpoint_ids": {"type": "array", "items": {"type": "string"}},
        "possible_boundary_decision_ids": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "weakest_evidence_id": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "attachment": {
      "type": "object",
      "required": ["attachment_id", "token_id", "target_type", "target_id", "role", "selected", "score"],
      "properties": {
        "attachment_id": {"type": "string"},
        "token_id": {"type": "string"},
        "target_type": {"enum": ["port", "network", "endpoint", "symbol", "page_zone"]},
        "target_id": {"type": "string"},
        "role": {"type": "string"},
        "selected": {"type": "boolean"},
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "reason_codes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "crossPageMatch": {
      "type": "object",
      "required": ["match_id", "source_endpoint_id", "target_endpoint_id", "selected", "score"],
      "properties": {
        "match_id": {"type": "string"},
        "source_endpoint_id": {"type": "string"},
        "target_endpoint_id": {"type": "string"},
        "canonical_identity": {"type": ["string", "null"]},
        "reciprocal": {"type": "boolean"},
        "selected": {"type": "boolean"},
        "score": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  },
  "additionalProperties": true
}
